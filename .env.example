# .env.example — Safe template to share on GitHub
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env to GitHub

# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=cloud/service_account.json

# Google Cloud Project ID (used for Google Earth Engine)
# Find this at: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
